<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="licitAdminDashboard.MainPage"
             BackgroundColor="#0f172a">


        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20">

                <Label Text="Auction Admin Dashboard"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />

                <!-- Summary cards -->
            <HorizontalStackLayout Spacing="15"
                       HorizontalOptions="FillAndExpand"
                       Margin="0,10,0,0">

                <Border BackgroundColor="#1e293b"
            Padding="20"
            WidthRequest="120"
            HorizontalOptions="Fill">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout>
                        <Label Text="Users" TextColor="White"/>
                        <Label x:Name="UsersCountLabel"
                   Text="0"
                   FontSize="24"
                   TextColor="#38bdf8"
                   FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#1e293b"
            Padding="20"
            WidthRequest="120"
            HorizontalOptions="Fill">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout>
                        <Label Text="Products" TextColor="White"/>
                        <Label x:Name="ProductsCountLabel"
                   Text="0"
                   FontSize="24"
                   TextColor="#22c55e"
                   FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#1e293b"
            Padding="20"
            WidthRequest="120"
            HorizontalOptions="Fill">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout>
                        <Label Text="Bids" TextColor="White"/>
                        <Label x:Name="BidsCountLabel"
                   Text="0"
                   FontSize="24"
                   TextColor="#f59e0b"
                   FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>

            </HorizontalStackLayout>

            <!-- Tabs -->
                <HorizontalStackLayout Spacing="15" Margin="0,20,0,0">

                <Button Text="Users"
        BackgroundColor="#3b82f6"
        TextColor="White"
                    x:Name="UsersBtn">

                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroupList>

                            <VisualStateGroup Name="CommonStates">
                                <VisualState Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="#3b82f6"/>
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="#2563eb"/>
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="#1d4ed8"/>
                                    </VisualState.Setters>
                                </VisualState>
                                
                            </VisualStateGroup>

                        </VisualStateGroupList>
                    </VisualStateManager.VisualStateGroups>
                </Button>

                <Button Text="Products"
                         BackgroundColor="#10b981"
                         TextColor="White"
                         x:Name="ProductsBtn">

                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroupList>

                            <VisualStateGroup Name="CommonStates">

                                <VisualState Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="#10b981"/>
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="#059669"/>
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="#047857"/>
                                    </VisualState.Setters>
                                </VisualState>

                            </VisualStateGroup>

                        </VisualStateGroupList>
                    </VisualStateManager.VisualStateGroups>
                </Button>

                <Button Text="Bids"
                     BackgroundColor="#f59e0b"
                     TextColor="White"
                     x:Name="BidsBtn">

                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroupList>

                            <VisualStateGroup Name="CommonStates">

                                <VisualState Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="#f59e0b"/>
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="#d97706"/>
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="#b45309"/>
                                    </VisualState.Setters>
                                </VisualState>

                            </VisualStateGroup>

                        </VisualStateGroupList>
                    </VisualStateManager.VisualStateGroups>
                </Button>


                <Button Text="Logout"
                     BackgroundColor="#ef4444"
                     TextColor="White"
                     x:Name="LogoutBtn"
                     Clicked="LogOutAdmin">

                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroupList>

                            <VisualStateGroup Name="CommonStates">

                                <VisualState Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="#ef4444"/>
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="#dc2626"/>
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="#b91c1c"/>
                                    </VisualState.Setters>
                                </VisualState>

                            </VisualStateGroup>

                        </VisualStateGroupList>
                    </VisualStateManager.VisualStateGroups>
                </Button>


            </HorizontalStackLayout>

                <!-- Users list -->
            <CollectionView x:Name="UsersList" IsVisible="True" Margin="0,10,0,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#1e293b" Padding="10" Margin="0,0,0,10">

                           
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                        NumberOfTapsRequired="2"
                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.UserDoubleTappedCommand}"
                        CommandParameter="{Binding Id}" />
                            </Border.GestureRecognizers>

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>

                            <StackLayout>
                                <Label Text="{Binding Name}" TextColor="White" FontAttributes="Bold"/>
                                <Label Text="{Binding Email}" TextColor="LightGray"/>
                                <Label Text="{Binding IsAdmin, StringFormat='Admin: {0}'}" TextColor="LightGray"/>
                                <Label Text="{Binding IsBanned, StringFormat='Banned: {0}'}" TextColor="LightGray"/>

                                <StackLayout Orientation="Horizontal" Spacing="10">
                                    <Button Text="Ban"
                                CommandParameter="{Binding Id}"
                                TextColor="White"
                                x:Name="BanBtn"
                                Clicked="OnBanClicked">

                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroupList>

                                                <VisualStateGroup Name="CommonStates">

                                                    <VisualState Name="Normal">
                                                        <VisualState.Setters>
                                                            <Setter Property="BackgroundColor" Value="#ef4444"/>
                                                        </VisualState.Setters>
                                                    </VisualState>

                                                    <VisualState Name="PointerOver">
                                                        <VisualState.Setters>
                                                            <Setter Property="BackgroundColor" Value="#dc2626"/>
                                                        </VisualState.Setters>
                                                    </VisualState>

                                                    <VisualState Name="Pressed">
                                                        <VisualState.Setters>
                                                            <Setter Property="BackgroundColor" Value="#b91c1c"/>
                                                        </VisualState.Setters>
                                                    </VisualState>

                                                </VisualStateGroup>

                                            </VisualStateGroupList>
                                        </VisualStateManager.VisualStateGroups>
                                    </Button>

                                    <Button Text="Unban"
                                CommandParameter="{Binding Id}"
                                TextColor="White"
                                x:Name="UnbanBtn"
                                Clicked="OnUnbanClicked">

                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroupList>

                                                <VisualStateGroup Name="CommonStates">

                                                    <VisualState Name="Normal">
                                                        <VisualState.Setters>
                                                            <Setter Property="BackgroundColor" Value="#22c55e"/>
                                                        </VisualState.Setters>
                                                    </VisualState>

                                                    <VisualState Name="PointerOver">
                                                        <VisualState.Setters>
                                                            <Setter Property="BackgroundColor" Value="#16a34a"/>
                                                        </VisualState.Setters>
                                                    </VisualState>

                                                    <VisualState Name="Pressed">
                                                        <VisualState.Setters>
                                                            <Setter Property="BackgroundColor" Value="#15803d"/>
                                                        </VisualState.Setters>
                                                    </VisualState>

                                                </VisualStateGroup>

                                            </VisualStateGroupList>
                                        </VisualStateManager.VisualStateGroups>
                                    </Button>

                                </StackLayout>
                            </StackLayout>

                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Products list -->
            <Button Text="Add Product" IsVisible="False" x:Name="AddProductbtn" TextColor="White"
                    BackgroundColor="#C9B05B" Padding="10" Margin="0,10,0,0" WidthRequest="200" Clicked="OpenNewProductPage">

                <VisualStateManager.VisualStateGroups>
                <VisualStateGroupList>

                    <VisualStateGroup Name="CommonStates">
                        <VisualState Name="Normal">
                            <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="#C9B05B"/>
                            </VisualState.Setters>
                        </VisualState>

                        <VisualState Name="PointerOver">
                            <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="#8C6E38"/>
                            </VisualState.Setters>
                        </VisualState>

                        <VisualState Name="Pressed">
                            <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="#725423"/>
                            </VisualState.Setters>
                        </VisualState>

                    </VisualStateGroup>

                </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
            </Button>
                
                <CollectionView x:Name="ProductsList" IsVisible="False" Margin="0,10,0,0">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#1e293b" Padding="10" Margin="0,0,0,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <StackLayout>
                                    <Label Text="{Binding Name}" TextColor="White" FontAttributes="Bold"/>
                                    <Label Text="{Binding Category}" TextColor="LightGray"/>
                                    <Label Text="{Binding StarterBid, StringFormat='Start Bid: {0:C}'}" TextColor="LightGray"/>
                                </StackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Bids list -->
                <CollectionView x:Name="BidsList" IsVisible="False" Margin="0,10,0,0">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#1e293b" Padding="10" Margin="0,0,0,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <StackLayout>
                                    <Label Text="{Binding Id, StringFormat='Bid ID: {0}'}" TextColor="White" FontAttributes="Bold"/>
                                    <Label Text="{Binding Amount, StringFormat='Amount: {0:C}'}" TextColor="LightGray"/>
                                    <Label Text="{Binding CreatedAt, StringFormat='Date: {0}'}" TextColor="LightGray"/>
                                </StackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>



            <!-- USER BIDS list -->
            <CollectionView x:Name="UserBidsList" IsVisible="False" Margin="0,10,0,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#1e293b" Padding="10" Margin="0,0,0,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <StackLayout>
                                <Label Text="{Binding Id, StringFormat='Bid ID: {0}'}" TextColor="White" FontAttributes="Bold"/>
                                <Label Text="{Binding Amount, StringFormat='Amount: {0:C}'}" TextColor="LightGray"/>
                                <Label Text="{Binding CreatedAt, StringFormat='Date: {0}'}" TextColor="LightGray"/>
                            </StackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
        </ScrollView>
    </ContentPage>
