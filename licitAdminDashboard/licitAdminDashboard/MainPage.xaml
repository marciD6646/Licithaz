<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="licitAdminDashboard.MainPage"
             BackgroundColor="#0f172a">


        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20">

                <Label Text="Auction Admin Dashboard"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />

                <!-- Summary cards -->
                <Grid ColumnDefinitions="*,*,*"
                  RowDefinitions="Auto"
                  ColumnSpacing="15"
                  RowSpacing="15">

                    <Border BackgroundColor="#1e293b"  Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout>
                            <Label Text="Users" TextColor="White"/>
                            <Label x:Name="UsersCountLabel" Text="0" FontSize="24" TextColor="#38bdf8" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border BackgroundColor="#1e293b" Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout>
                            <Label Text="Products" TextColor="White"/>
                            <Label x:Name="ProductsCountLabel" Text="0" FontSize="24" TextColor="#22c55e" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border BackgroundColor="#1e293b" Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout>
                            <Label Text="Bids" TextColor="White"/>
                            <Label x:Name="BidsCountLabel" Text="0" FontSize="24" TextColor="#f59e0b" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Tabs -->
                <HorizontalStackLayout Spacing="15" Margin="0,20,0,0">
                    <Button Text="Users" x:Name="UsersBtn" BackgroundColor="#3b82f6" TextColor="White"/>
                    <Button Text="Products" x:Name="ProductsBtn" BackgroundColor="#10b981" TextColor="White"/>
                    <Button Text="Bids" x:Name="BidsBtn" BackgroundColor="#f59e0b" TextColor="White"/>
                    <Button Text="Logout" x:Name="LogoutBtn" Background="Red" TextColor="White" Clicked="LogOutAdmin"/>
            </HorizontalStackLayout>

                <!-- Users list -->
                <CollectionView x:Name="UsersList" IsVisible="True" Margin="0,10,0,0">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#1e293b" Padding="10" Margin="0,0,0,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <StackLayout>
                                    <Label Text="{Binding Name}" TextColor="White" FontAttributes="Bold"/>
                                    <Label Text="{Binding Email}" TextColor="LightGray"/>
                                    <Label Text="{Binding IsAdmin, StringFormat='Admin: {0}'}" TextColor="LightGray"/>
                                    <Label Text="{Binding IsBanned, StringFormat='Banned: {0}'}" TextColor="LightGray"/>
                                <StackLayout Orientation="Horizontal" Spacing="10">
                                    <Button Text="Ban"
                                         CommandParameter="{Binding Id}"
                                         BackgroundColor="Red"
                                         Clicked="OnBanClicked"
                                         TextColor="White"/>

                                    <Button Text="Unban"
                                         Clicked="OnUnbanClicked"
                                         CommandParameter="{Binding Id}"
                                         BackgroundColor="Green"
                                         TextColor="White"/>
                                </StackLayout>
                            </StackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Products list -->
                <CollectionView x:Name="ProductsList" IsVisible="False" Margin="0,10,0,0">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#1e293b" Padding="10" Margin="0,0,0,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <StackLayout>
                                    <Label Text="{Binding Name}" TextColor="White" FontAttributes="Bold"/>
                                    <Label Text="{Binding Category}" TextColor="LightGray"/>
                                    <Label Text="{Binding StarterBid, StringFormat='Start Bid: {0:C}'}" TextColor="LightGray"/>
                                </StackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Bids list -->
                <CollectionView x:Name="BidsList" IsVisible="False" Margin="0,10,0,0">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#1e293b" Padding="10" Margin="0,0,0,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <StackLayout>
                                    <Label Text="{Binding Id, StringFormat='Bid ID: {0}'}" TextColor="White" FontAttributes="Bold"/>
                                    <Label Text="{Binding Amount, StringFormat='Amount: {0:C}'}" TextColor="LightGray"/>
                                    <Label Text="{Binding CreatedAt, StringFormat='Date: {0}'}" TextColor="LightGray"/>
                                </StackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </ContentPage>