<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="licitAdminDashboard.EditProductPage"
             Title="Edit Product"
             BackgroundColor="#0f172a">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Edit Product"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <Entry x:Name="NameEntry"
                   Placeholder="Product Name"
                   TextColor="White"
                   BackgroundColor="#1e293b"/>

            <Picker x:Name="CategoryPicker"
                    Title="Select Category"
                    BackgroundColor="#1e293b"
                    TextColor="White">
                <Picker.Items>
                    <x:String>Electronics</x:String>
                    <x:String>Books</x:String>
                    <x:String>Clothing</x:String>
                    <x:String>House</x:String>
                    <x:String>Sports</x:String>
                    <x:String>Vehicles</x:String>
                    <x:String>Jewelry</x:String>
                </Picker.Items>
            </Picker>

            <Editor x:Name="DescriptionEditor"
                    Placeholder="Short Description"
                    HeightRequest="80"
                    TextColor="White"
                    BackgroundColor="#1e293b"/>

            <Editor x:Name="ExtendedDescriptionEditor"
                    Placeholder="Extended Description"
                    HeightRequest="120"
                    TextColor="White"
                    BackgroundColor="#1e293b"/>

            <Button Text="Change Image"
                    Clicked="OnPickImageClicked"
                    BackgroundColor="#334155"
                    TextColor="White"/>

            <Image x:Name="PreviewImage"
                   HeightRequest="150"
                   Aspect="AspectFill"/>

            <Entry x:Name="StarterBidEntry"
                   Placeholder="Starter Bid"
                   Keyboard="Numeric"
                   TextColor="White"
                   BackgroundColor="#1e293b"/>


            <Label Text="Bid Dates"
       TextColor="White"
       FontAttributes="Bold"
       Margin="0,10,0,0"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">

                <VerticalStackLayout>
                    <Label Text="Start Date"
               TextColor="Gray"
               FontSize="12"/>
                    <DatePicker x:Name="StartDatePicker"
                    TextColor="White"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1">
                    <Label Text="End Date"
               TextColor="Gray"
               FontSize="12"/>
                    <DatePicker x:Name="EndDatePicker"
                    TextColor="White"/>
                </VerticalStackLayout>

            </Grid>

            <Button Text="Update Product"
        Clicked="OnUpdateProductClicked"
        TextColor="White">

                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>

                        <VisualStateGroup Name="CommonStates">

                            <VisualState Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="#22c55e"/>
                                </VisualState.Setters>
                            </VisualState>

                            <VisualState Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="#16a34a"/>
                                </VisualState.Setters>
                            </VisualState>

                            <VisualState Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="#15803d"/>
                                </VisualState.Setters>
                            </VisualState>

                        </VisualStateGroup>

                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
            </Button>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>