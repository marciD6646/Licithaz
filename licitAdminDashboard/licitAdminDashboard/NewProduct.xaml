<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="licitAdminDashboard.NewProduct"
             Title="Add New Product"
             BackgroundColor="#0f172a">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Add New Product"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <Entry Placeholder="Product Name"
                   x:Name="NameEntry"
                   TextColor="White"
                   BackgroundColor="#1e293b"/>

            <Picker x:Name="CategoryPicker"
                    Title="Select Category"
                    BackgroundColor="#1e293b"
                    TextColor="White">
                <Picker.Items>
                    <x:String>Electronics</x:String>
                    <x:String>Books</x:String>
                    <x:String>Clothing</x:String>
                </Picker.Items>
            </Picker>

            <Editor x:Name="DescriptionEditor"
                    Placeholder="Short Description"
                    HeightRequest="80"
                    TextColor="White"
                    BackgroundColor="#1e293b"/>

            <Editor x:Name="ExtendedDescriptionEditor"
                    Placeholder="Extended Description"
                    HeightRequest="120"
                    TextColor="White"
                    BackgroundColor="#1e293b"/>

            <!-- 📸 IMAGE -->
            <Button Text="Choose Image"
                    Clicked="OnPickImageClicked"
                    BackgroundColor="#334155"
                    TextColor="White"/>

            <Image x:Name="PreviewImage"
                   HeightRequest="150"
                   Aspect="AspectFill"/>

            <Entry x:Name="StarterBidEntry"
                   Placeholder="Starter Bid"
                   Keyboard="Numeric"
                   TextColor="White"
                   BackgroundColor="#1e293b"/>

            <Label Text="Bid Dates"
       TextColor="White"
       FontAttributes="Bold"
       Margin="0,10,0,0"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">

                <VerticalStackLayout>
                    <Label Text="Start Date"
               TextColor="Gray"
               FontSize="12"/>
                    <DatePicker x:Name="StartDatePicker"
                    TextColor="White"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1">
                    <Label Text="End Date"
               TextColor="Gray"
               FontSize="12"/>
                    <DatePicker x:Name="EndDatePicker"
                    TextColor="White"/>
                </VerticalStackLayout>

            </Grid>

            <Button Text="Add Product"
                    Clicked="OnSubmitProductClicked"
                    BackgroundColor="#C9B05B"
                    TextColor="White"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>